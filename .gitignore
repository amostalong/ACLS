# Unity generated / machine-local directories.
# Patterns are unanchored so they match the Unity project nested under ACLS_Unity/.
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# Asset Store tools (uncomment if used)
# [Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin assets
[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache
.vs/

# Gradle cache
.gradle/

# Autogenerated VS / Rider / MD project & solution files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity-generated meta files for the above
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity crash reports
sysinfo.txt

# Build artifacts
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics
crashlytics-build.properties

# Packed Addressables
[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Auto-generated Android streaming assets
[Aa]ssets/[Ss]treamingAssets/aa.meta
[Aa]ssets/[Ss]treamingAssets/aa/*

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Claude Code workspace metadata (local to this checkout, not part of the Unity project).
# Remove these lines if you want to share project-scoped skills/settings with the team.
/.claude/
/memory/

# LLM config — contains API key, must never be committed.
ACLS_Unity/Assets/Resources/LlmConfig.asset
ACLS_Unity/Assets/Resources/LlmConfig.asset.meta

# IDE
.idea/
.trae/

# Locus package (local/private, not for version control)
ACLS_Unity/Locus/
ACLS_Unity/Packages/com.farlocus.locus/
