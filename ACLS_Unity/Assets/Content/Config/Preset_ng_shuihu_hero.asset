  Id: ng_shuihu_hero
  Title: "\u6C34\u6D52\xB7\u6881\u5C71\u597D\u6C49"
  Era: "\u5317\u5B8B\xB7\u653F\u548C\u5E74\u95F4\uFF081111-1118\uFF09"
  Description: "\u5B98\u903C\u6C11\u53CD \xB7 \u66FF\u5929\u884C\u9053"
  IsCustom: 0
  WorldBlurb: "\u5317\u5B8B\u653F\u548C\u5E74\u95F4\uFF0C\u5FBD\u5B97\u5728\u4F4D\uFF0C\u8521\u4EAC\u3001\u9AD8\u4FC5\u7B49\u5978\u81E3\u5F53\u9053\uFF0C\u8D2A\u5B98\u6C61\u540F\u6A2A\u884C\u4E61\u91CC\u3002\u6881\u5C71\u6CCA\u6C34\u6CCA\u516B\u767E\u91CC\uFF0C\u805A\u4E49\u5385\u524D\u674F\u9EC4\u65D7\u8FCE\u98CE\u730E\u730E\u2014\u2014\u300C\u66FF\u5929\u884C\u9053\u300D\u56DB\u4E2A\u5927\u5B57\u4E0B\uFF0C\u4E00\u767E\u5355\u516B\u5C06\u7684\u4F20\u8BF4\u6B63\u4ECE\u6C5F\u6E56\u7684\u6BCF\u4E00\u4E2A\u89D2\u843D\u6C47\u805A\u800C\u6765\u3002\u6797\u51B2\u96EA\u591C\u4E0A\u6881\u5C71\u3001\u6B66\u677E\u666F\u9633\u5188\u6253\u864E\u3001\u9C81\u667A\u6DF1\u5012\u62D4\u5782\u6768\u67F3\u2014\u2014\u8FD9\u4E9B\u540D\u5B57\u54CD\u5F7B\u5927\u6C5F\u5357\u5317\uFF0C\u5929\u4E0B\u82F1\u96C4\u95FB\u98CE\u800C\u52A8\u3002\u7136\u800C\u671D\u5EF7\u5341\u4E07\u5927\u519B\u5DF2\u9648\u5175\u6C34\u6CCA\u4E4B\u7554\uFF0C\u6881\u5C71\u7684\u524D\u8DEF\u8FF7\u96FE\u91CD\u91CD\u3002"
  CharBlurb: "\u4F60\u672C\u662F\u5C71\u4E1C\u90D3\u57CE\u53BF\u7684\u4E00\u540D\u666E\u901A\u767E\u59D3\uFF0C\u56E0\u62B1\u6253\u4E0D\u5E73\u5F97\u7F6A\u4E86\u5F53\u5730\u6076\u9738\uFF0C\u88AB\u8BEC\u9677\u5165\u72F1\u3002\u8D8A\u72F1\u540E\u6D41\u843D\u6C5F\u6E56\uFF0C\u542C\u95FB\u6881\u5C71\u6CCA\u62DB\u8D24\u7EB3\u58EB\u3001\u66FF\u5929\u884C\u9053\uFF0C\u5FC3\u4E2D\u71C3\u8D77\u4E00\u4E1D\u5E0C\u671B\u3002\u4F60\u6709\u4E00\u8EAB\u529B\u6C14\u548C\u51E0\u5206\u80C6\u8272\uFF0C\u5374\u4E0D\u77E5\u8FD9\u4E71\u4E16\u4E4B\u4E2D\uFF0C\u4E00\u4E2A\u65E0\u540D\u4E4B\u8F88\u80FD\u5426\u5728\u6C34\u6CCA\u6881\u5C71\u95EF\u51FA\u81EA\u5DF1\u7684\u540D\u53F7\u3002"
  LocationName: "\u6881\u5C71\u6CCA"
