  Title: "\u5C04\u96D5\xB7\u5927\u6F20\u5B64\u4FA0"
  Era: "\u5357\u5B8B\xB7\u5E86\u5143\u5E74\u95F4"
  Description: "\u8499\u53E4\u5357\u4FB5 \xB7 \u4FA0\u4E4B\u5927\u8005\u4E3A\u56FD\u4E3A\u6C11"
  IsCustom: 0
  WorldBlurb: "\u5357\u5B8B\u5E86\u5143\u5E74\u95F4\uFF0C\u8499\u53E4\u94C1\u9A91\u5E2D\u5377\u5927\u6F20\uFF0C\u91D1\u56FD\u5DF2\u662F\u5F3A\u5F29\u4E4B\u672B\u3002\u4E2D\u539F\u6B66\u6797\u6697\u6D41\u6D8C\u52A8\u2014\u2014\u5168\u771F\u6559\u91CD\u9633\u771F\u4EBA\u7FBD\u5316\u540E\uFF0C\u5168\u771F\u4E03\u5B50\u52C9\u529B\u7EF4\u6301\uFF1B\u5929\u4E0B\u4E94\u7EDD\u4E4B\u540D\u9707\u52A8\u6C5F\u6E56\uFF0C\u534E\u5C71\u8BBA\u5251\u7684\u4F20\u8BF4\u4ECD\u5728\u6D41\u4F20\u3002\u5728\u8FD9\u738B\u671D\u66F4\u8FED\u3001\u6B66\u6797\u7EB7\u4E89\u7684\u5927\u65F6\u4EE3\uFF0C\u4F60\u4ECE\u725B\u5BB6\u6751\u7684\u4E00\u76CF\u5B64\u706F\u4E2D\u9192\u6765\u3002"
  CharBlurb: "\u81EA\u5E7C\u5728\u6C5F\u5357\u725B\u5BB6\u6751\u957F\u5927\u7684\u5B64\u513F\uFF0C\u4E0D\u77E5\u7236\u6BCD\u4E3A\u8C01\u3002\u517B\u7236\u662F\u6751\u4E2D\u94C1\u5320\uFF0C\u6559\u4F1A\u4E86\u4F60\u6253\u94C1\u7684\u624B\u827A\u548C\u51E0\u624B\u7C97\u6D45\u62F3\u811A\u3002\u4E00\u65E5\uFF0C\u4E00\u7FA4\u9ED1\u8863\u4EBA\u5728\u6751\u4E2D\u51FA\u6CA1\uFF0C\u517B\u7236\u4E34\u6B7B\u524D\u585E\u7ED9\u4F60\u534A\u5757\u523B\u7740\u5947\u602A\u82B1\u7EB9\u7684\u7389\u4F69\u3002\u4F60\u4E0D\u77E5\u9053\u8FD9\u7389\u4F69\u610F\u5473\u7740\u4EC0\u4E48\uFF0C\u53EA\u77E5\u9053\u90A3\u4E9B\u9ED1\u8863\u4EBA\u6765\u81EA\u91D1\u56FD\u3002"
