  m_Name: Preset_ng_guanzhong_frontier
  m_EditorClassIdentifier: 
  Id: ng_tianlong_blade
  Title: "\u5929\u9F99\xB7\u4E71\u4E16\u4FA0\u5F71"
  Era: "\u5317\u5B8B\xB7\u5143\u7950\u5E74\u95F4"
  Description: "\u8FBD\u590F\u5B8B\u5927\u7406 \xB7 \u5BB6\u56FD\u6069\u4EC7"
  IsCustom: 0
  WorldBlurb: "\u5317\u5B8B\u5143\u7950\u5E74\u95F4\uFF0C\u5927\u5B8B\u4E0E\u8FBD\u56FD\u5DF2\u767E\u5E74\u65E0\u5927\u6218\uFF0C\u897F\u590F\u5374\u5C61\u5C61\u72AF\u8FB9\u3002\u6C5F\u6E56\u4E4B\u4E0A\uFF0C\u5C11\u6797\u5BFA\u4ECD\u662F\u6B66\u6797\u6CF0\u6597\uFF1B\u59D1\u82CF\u6155\u5BB9\u6C0F\u7684\u300C\u4EE5\u5F7C\u4E4B\u9053\u8FD8\u65BD\u5F7C\u8EAB\u300D\u4EE4\u4EBA\u95FB\u98CE\u4E27\u80C6\uFF1B\u4E10\u5E2E\u5E2E\u4E3B\u4E54\u5CF0\u4EE5\u4E00\u5957\u964D\u9F99\u5341\u516B\u638C\u5A01\u9707\u5929\u4E0B\uFF1B\u5927\u7406\u6BB5\u6C0F\u7684\u4E00\u9633\u6307\u72EC\u6B65\u897F\u5357\u3002\u8868\u9762\u592A\u5E73\u76DB\u4E16\uFF0C\u5B9E\u5219\u6697\u6D41\u6C79\u6D8C\u2014\u2014\u5951\u4E39\u4EBA\u7684\u590D\u56FD\u9634\u8C0B\u3001\u6155\u5BB9\u5BB6\u7684\u60CA\u5929\u91CE\u5FC3\uFF0C\u6B63\u5C06\u6240\u6709\u4EBA\u7684\u547D\u8FD0\u7F16\u7EC7\u5728\u4E00\u8D77\u3002"
  CharBlurb: "\u4F60\u51FA\u8EAB\u4E00\u4E2A\u4E0D\u8D77\u773C\u7684\u6B66\u6797\u4E16\u5BB6\uFF0C\u7956\u4E0A\u66FE\u53C2\u4E0E\u96C1\u95E8\u5173\u4E00\u5F79\u3002\u5BB6\u4E2D\u85CF\u6709\u4E00\u67C4\u9508\u8FF9\u6591\u6591\u7684\u94C1\u5251\u548C\u4E00\u5377\u6B8B\u7F3A\u4E0D\u5168\u7684\u5185\u529F\u5FC3\u6CD5\u3002\u4F60\u4ECE\u5C0F\u542C\u7740\u7956\u4E0A\u7684\u4F20\u8BF4\u957F\u5927\uFF0C\u5FC3\u4E2D\u5374\u53EA\u6709\u4E00\u8154\u5C11\u5E74\u610F\u6C14\u3002\u90A3\u4E00\u65E5\uFF0C\u4E00\u4E2A\u81EA\u79F0\u6765\u81EA\u897F\u590F\u4E00\u54C1\u5802\u7684\u795E\u79D8\u5973\u4EBA\u51FA\u73B0\u5728\u4F60\u9762\u524D\u3002"
  LocationName: "\u96C1\u95E8"
  TraitId: 0
