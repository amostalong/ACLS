  WorldBlurb: "\u6218\u56FD\u672B\u671F\uFF0C\u79E6\u52BF\u65E5\u76DB\uFF0C\u516D\u56FD\u5371\u5982\u7D2F\u5375\u3002\u957F\u5E73\u4E4B\u6218\u540E\u8D75\u56FD\u5143\u6C14\u5927\u4F24\uFF0C\u7EB5\u6A2A\u4E4B\u58EB\u5954\u8D70\u5217\u56FD\uFF0C\u5408\u7EB5\u8FDE\u6A2A\u4E4B\u672F\u5927\u884C\u5176\u9053\u3002\u5929\u4E0B\u5C06\u5B9A\u672A\u5B9A\uFF0C\u6B63\u662F\u6E38\u58EB\u7528\u547D\u4E4B\u65F6\u3002\u6D1B\u9633\u5468\u5929\u5B50\u867D\u540D\u5B58\u5B9E\u4EA1\uFF0C\u4ECD\u662F\u5404\u65B9\u52BF\u529B\u6697\u4E2D\u89D2\u9010\u4E4B\u5730\u3002"
  CharBlurb: "\u5C11\u4E60\u7EB5\u6A2A\u672F\uFF0C\u901A\u6653\u5217\u56FD\u5927\u52BF\u3002\u5BB6\u9053\u4E2D\u843D\u540E\u6E38\u5386\u56DB\u65B9\uFF0C\u4EE5\u820C\u8FA9\u4E3A\u751F\u3002\u80F8\u85CF\u5217\u56FD\u56FE\uFF0C\u638C\u63E1\u5929\u4E0B\u5F62\u52BF\uFF0C\u53EA\u6B20\u4E00\u5C55\u62B1\u8D1F\u4E4B\u673A\u3002"
