  m_EditorClassIdentifier: 
  Id: ng_xiyou_pilgrim
  Title: "\u897F\u6E38\xB7\u884C\u811A\u5929\u6DAF"
  Era: "\u5510\xB7\u8D1E\u89C2\u5E74\u95F4"
  Description: "\u5996\u96FE\u5F25\u6F2B \xB7 \u5927\u9053\u897F\u884C"
  IsCustom: 0
  WorldBlurb: "\u5510\u8D1E\u89C2\u5E74\u95F4\uFF0C\u957F\u5B89\u57CE\u4E07\u56FD\u6765\u671D\uFF0C\u4F5B\u6CD5\u660C\u9686\u3002\u592A\u5B97\u68A6\u4E2D\u9047\u9B3C\uFF0C\u9192\u6765\u540E\u5927\u5174\u4F5B\u4E8B\uFF0C\u4E09\u85CF\u6CD5\u5E08\u5949\u65E8\u897F\u884C\u53D6\u7ECF\u3002\u7136\u800C\u81EA\u90A3\u4EE5\u540E\uFF0C\u5929\u4E0B\u5996\u6C14\u6E10\u76DB\u2014\u2014\u897F\u884C\u8DEF\u4E0A\u767D\u9AA8\u6210\u7CBE\u3001\u72D0\u5996\u76D8\u8E1E\uFF1B\u4E1C\u6D77\u9F99\u5BAB\u6697\u6D41\u6D8C\u52A8\uFF1B\u4E94\u884C\u5C71\u4E0B\u538B\u4E86\u4E94\u767E\u5E74\u7684\u77F3\u7334\uFF0C\u4ECD\u5728\u7B49\u5F85\u6709\u7F18\u4EBA\u63ED\u4E0B\u90A3\u5F20\u7B26\u5492\u3002\u5929\u5EAD\u4E0E\u7075\u5C71\u7684\u6697\u4E2D\u89D2\u529B\uFF0C\u5DF2\u5C06\u4E09\u754C\u4F17\u751F\u5377\u5165\u4E00\u573A\u56E0\u679C\u5927\u52AB\u3002"
  CharBlurb: "\u4F60\u662F\u957F\u5B89\u57CE\u5916\u6148\u6069\u5BFA\u7684\u4E00\u540D\u4FD7\u5BB6\u5F1F\u5B50\uFF0C\u4ECE\u5C0F\u88AB\u5E08\u7236\u6536\u517B\uFF0C\u4F1A\u4E00\u4E9B\u7C97\u6D45\u4F5B\u6CD5\u548C\u9632\u8EAB\u6B66\u827A\u3002\u5E08\u7236\u5706\u5BC2\u524D\u544A\u8BC9\u4F60\uFF1A\u4F60\u7684\u8EAB\u4E16\u4E0E\u4E94\u884C\u5C71\u4E0B\u7684\u90A3\u4E2A\u77F3\u7334\u6709\u5173\u3002\u4F60\u4E0D\u4FE1\uFF0C\u76F4\u5230\u90A3\u665A\u4F60\u68A6\u89C1\u4E00\u53EA\u91D1\u6BDB\u5DE8\u733F\u5BF9\u4F60\u8BF4\u2014\u2014\u300C\u63ED\u4E86\u90A3\u5F20\u7B26\uFF0C\u4FFA\u8001\u5B59\u5E26\u4F60\u6405\u7FFB\u8FD9\u5929\u3002\u300D"
  LocationName: "\u957F\u5B89"
  TraitId: 0
  TraitLabel: 
  Lists: 1
