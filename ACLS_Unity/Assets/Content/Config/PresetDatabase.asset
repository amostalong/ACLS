  WorldBlurb: "\u6C5F\u6E56\u4E0E\u5E99\u5802\u5E76\u5B58\u4E4B\u4E16\u3002\u6B66\u6797\u4E03\u5927\u6D3E\u7CFB\u5206\u636E\u4E94\u5CB3\u56DB\u6D77\uFF0C\u671D\u5EF7\u4EE5\u300C\u9547\u6B66\u53F8\u300D\u5236\u8861\u6B66\u6797\u3002\u4ECA\u5E74\u6070\u9022\u5341\u5E74\u4E00\u5EA6\u300C\u5929\u4E0B\u8BBA\u6B66\u300D\uFF0C\u5404\u6D3E\u5C11\u4FA0\u9F50\u805A\u6D1B\u9633\u3002\u6697\u5730\u91CC\uFF0C\u4E00\u6869\u7275\u626F\u671D\u5EF7\u4E0E\u6B66\u6797\u7684\u60CA\u5929\u79D8\u5BC6\u6B63\u5728\u6D6E\u51FA\u6C34\u9762\u3002\u8C01\u4E3B\u6C89\u6D6E\uFF0C\u672A\u6709\u5B9A\u6570\u3002"
