  m_Name: Preset_ng_yingchuan_scholar
  m_EditorClassIdentifier: 
  Id: ng_yingchuan_scholar
  Title: "\u4E09\u56FD\xB7\u988D\u5DDD\u5BD2\u95E8"
  Era: "\u4E1C\u6C49\xB7\u4E2D\u5E73\u5143\u5E74\uFF08184\uFF09"
  Description: "\u9EC4\u5DFE\u521D\u8D77 \xB7 \u5929\u4E0B\u98CE\u4E91\u9645\u4F1A"
  IsCustom: 0
  WorldBlurb: "\u4E1C\u6C49\u4E2D\u5E73\u5143\u5E74\uFF0C\u9EC4\u5DFE\u4E4B\u4E71\u65B9\u5174\u3002\u671D\u653F\u65E5\u8870\uFF0C\u8C6A\u5F3A\u5E76\u8D77\uFF0C\u5929\u4E0B\u5C06\u4E71\u672A\u4E71\u3002\u988D\u5DDD\u4E3A\u5929\u4E0B\u6587\u67A2\uFF0C\u8340\u6C0F\u3001\u9648\u6C0F\u3001\u949F\u6C0F\u7B49\u5927\u65CF\u76D8\u8E1E\uFF0C\u5BD2\u95E8\u5B50\u5F1F\u6B32\u51FA\u5934\u96BE\u5982\u767B\u5929\u3002\u7136\u800C\u4E71\u4E16\u51FA\u82F1\u96C4\u2014\u2014\u66F9\u64CD\u5728\u9648\u7559\u6563\u5BB6\u8D22\u52DF\u4E49\u5175\uFF0C\u5218\u5907\u4E8E\u6DBF\u90E1\u7EC7\u5E2D\u8D29\u5C65\uFF0C\u5B59\u575A\u5728\u957F\u6C99\u8DC3\u9A6C\u626C\u97AD\u3002\u4E09\u56FD\u7684\u5E8F\u7AE0\u5DF2\u7ECF\u4ECE\u988D\u5DDD\u7684\u4E61\u91CE\u95F4\u6084\u7136\u7FFB\u5F00\u3002"
  CharBlurb: "\u51FA\u8EAB\u988D\u5DDD\u5BD2\u5FAE\u4E66\u5BB6\uFF0C\u7236\u65E9\u901D\uFF0C\u8D56\u6BCD\u52B3\u4F5C\u5EA6\u65E5\u3002\u5BB6\u85CF\u7ECF\u53F2\u6570\u5377\uFF0C\u81EA\u5C0F\u55DC\u8BFB\uFF0C\u5C24\u597D\u5175\u4E66\u6218\u7B56\u3002\u95FB\u9648\u5BD4\u8BBE\u9986\u6388\u5F92\uFF0C\u5FC3\u5411\u5F80\u4E4B\uFF0C\u7136\u5BB6\u8D2B\u65E0\u4EE5\u4E3A\u8D3D\u3002\u4F60\u7AD9\u5728\u988D\u6C34\u4E4B\u7554\uFF0C\u671B\u7740\u5BF9\u5CB8\u706F\u706B\u901A\u660E\u7684\u8340\u6C0F\u5E84\u56ED\uFF0C\u63E1\u7D27\u4E86\u624B\u4E2D\u7684\u7AF9\u7B80\u3002\u4E71\u4E16\u5DF2\u81F3\uFF0C\u8BFB\u4E66\u4EBA\u7684\u8DEF\u4E0D\u5728\u4E66\u658B\u91CC\uFF0C\u800C\u5728\u5929\u4E0B\u3002"
  LocationName: "\u988D\u5DDD"
  TraitId: 0
  TraitLabel: 
  Lists: 1
