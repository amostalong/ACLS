  IsCustom: 0
  WorldBlurb: "\u5929\u5B9D\u4E09\u8F7D\uFF0C\u674E\u5510\u5982\u65E5\u4E2D\u5929\u3002\u957F\u5B89\u57CE\u5185\u80E1\u5546\u4E91\u96C6\uFF0C\u4E1D\u7EF8\u4E4B\u8DEF\u9A7C\u94C3\u4E0D\u7EDD\u3002\u7136\u5E9C\u5175\u5236\u5DF2\u5D29\uFF0C\u85E9\u9547\u4E4B\u60A3\u9690\u9690\u4F5C\u75DB\u3002\u8FB9\u585E\u70FD\u70DF\u65F6\u800C\u9AA4\u8D77\uFF0C\u76DB\u4E16\u4E4B\u4E0B\u6697\u6D41\u6C79\u6D8C\u3002\u7FF0\u6797\u4F9B\u5949\u674E\u767D\u8D50\u91D1\u653E\u8FD8\uFF0C\u5929\u4E0B\u6E38\u4FA0\u95FB\u98CE\u800C\u52A8\u3002"
  CharBlurb: "\u51FA\u8EAB\u5173\u9647\u6CA1\u843D\u6B66\u5BB6\uFF0C\u5C11\u5B66\u5251\u672F\u9A91\u5C04\uFF0C\u597D\u8BFB\u6E38\u4FA0\u5217\u4F20\u3002\u5F80\u6765\u957F\u5B89\u5E02\u4E95\uFF0C\u7ED3\u4EA4\u4E09\u6559\u4E5D\u6D41\u3002\u80F8\u6000\u4FA0\u4E49\u5374\u65E0\u95E8\u8DEF\uFF0C\u53EA\u613F\u4ED7\u5251\u8D70\u5929\u6DAF\u95EF\u4E00\u756A\u58F0\u540D\u3002"
