  m_Name: Preset_ng_starsea_remnant
  m_EditorClassIdentifier: 
  Id: ng_starsea_remnant
  Title: "\u661F\u6D77\u9057\u6C11"
  Era: "\u79D1\u5E7B\xB7\u94F6\u6CB3\u7EAA\u5143 2247"
  Description: "\u8FB9\u7F18\u661F\u533A \xB7 \u8D70\u79C1\u8005\u4E3A\u751F"
  IsCustom: 0
  WorldBlurb: "\u516C\u51432247\u5E74\uFF0C\u4EBA\u7C7B\u65E9\u5DF2\u79BB\u5F00\u5944\u5944\u4E00\u606F\u7684\u5730\u7403\uFF0C\u5728\u94F6\u6CB3\u7CFB\u65CB\u81C2\u5EFA\u7ACB\u6570\u5341\u4E2A\u6B96\u6C11\u661F\u7CFB\u3002\u300C\u6CDB\u94F6\u6CB3\u8054\u90A6\u300D\u540D\u4E49\u4E0A\u7EDF\u5408\u5404\u661F\u7CFB\uFF0C\u5B9E\u5219\u6D3E\u7CFB\u6797\u7ACB\u3001\u6697\u6D41\u6C79\u6D8C\u3002\u8FB9\u7F18\u661F\u533A\u5728\u8054\u90A6\u6CD5\u5F8B\u97AD\u957F\u83AB\u53CA\u4E4B\u5730\u81EA\u6C42\u751F\u8DEF\u3002\u4E00\u8258\u5931\u8E2A\u767E\u5E74\u7684\u300C\u65B9\u821F\u7EA7\u300D\u6B96\u6C11\u8239\u8FD1\u65E5\u88AB\u91CD\u65B0\u53D1\u73B0\uFF0C\u5176\u642D\u8F7D\u7684\u524D\u4E16\u4EE3AI\u636E\u79F0\u638C\u63E1\u5931\u843D\u7684\u8DC3\u8FC1\u79D1\u6280\u3002\u5404\u65B9\u52BF\u529B\u95FB\u98CE\u800C\u52A8\uFF0C\u661F\u6D77\u518D\u8D77\u6CE2\u6F9C\u3002"
  CharBlurb: "\u51FA\u751F\u5728\u8FB9\u7F18\u661F\u533A\u7A7A\u95F4\u7AD9\u7684\u7B2C\u4E09\u4EE3\u79FB\u6C11\u3002\u7236\u6BCD\u662F\u661F\u9645\u8D27\u8FD0\u6280\u5E08\uFF0C\u4E8B\u6545\u53BB\u4E16\u540E\u72EC\u81EA\u8C0B\u751F\u3002\u5728\u7AD9\u533A\u4FEE\u7406\u65E7\u98DE\u8239\u548C\u4E49\u4F53\u88C5\u7F6E\u4E3A\u751F\uFF0C\u624B\u4E0A\u529F\u592B\u4E0D\u9519\uFF0C\u8111\u5B50\u91CC\u88C5\u7740\u534A\u4E2A\u661F\u7CFB\u7684\u8D70\u79C1\u8DEF\u7EBF\u3002\u5BF9\u8054\u90A6\u7684\u5BA3\u4F20\u55E4\u4E4B\u4EE5\u9F3B\uFF0C\u4F46\u4E0D\u4ECB\u610F\u63A5\u8054\u90A6\u7684\u6D3B\u513F\u8D5A\u4FE1\u7528\u70B9\u3002"
  LocationName: "\u65B0\u5E0C\u671B\u7AD9"
  TraitId: 3
  TraitLabel: "\u597D\u5B66"
  Lists: 5
